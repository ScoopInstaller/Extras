{
    "version": "3.9.7",
    "description": "Machine learning package",
    "homepage": "https://www.cs.waikato.ac.nz/ml/weka/",
    "license": "GPL-3.0-only",
    "url": "https://downloads.sourceforge.net/project/weka/weka-3-9/3.9.7/weka-3-9-7.zip",
    "hash": "26f6856a815552f10a5efc9ebad3b8d6538bac72b63561a04eb1b41073bb7cf6",
    "extract_dir": "weka-3-9-7",
    "bin": "weka.jar",
    "shortcuts": [
        [
            "weka.jar",
            "weka"
        ]
    ],
    "env_set": {
        "WEKA_HOME": "$dir\\wekafiles"
    },
    "persist": "wekafiles",
    "checkver": {
        "url": "https://sourceforge.net/projects/weka/rss?path=/weka-3-9",
        "regex": "weka-(?<major>\\d+)-(?<minor>\\d+)-(?<patch>\\d+)\\.zip",
        "replace": "${major}.${minor}.${patch}"
    },
    "autoupdate": {
        "url": "https://downloads.sourceforge.net/project/weka/weka-3-9/$version/weka-$matchMajor-$matchMinor-$matchPatch.zip",
        "extract_dir": "weka-$matchMajor-$matchMinor-$matchPatch"
    }
}
