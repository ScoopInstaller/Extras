{
    "version": "6.2.5",
    "description": "Multi-protocol and Java-based message broker",
    "homepage": "https://activemq.apache.org",
    "license": "Apache-2.0",
    "suggest": {
        "java": [
            "java/openjdk9",
            "java/corretto8-jre"
        ]
    },
    "notes": "Install service manually via '$dir\\bin\\winXX\\InstallService.bat'",
    "url": "https://downloads.apache.org/activemq/6.2.5/apache-activemq-6.2.5-bin.zip",
    "hash": "sha512:63d46397554d51bb907ae12cdb3e0b432bd05fe67106684096c3646fb3f31300f88830f283b860c470c63fe553e81a5cfb974d2f10c9308fdd5c64aac37b7f2c",
    "extract_dir": "apache-activemq-6.2.5",
    "bin": [
        "bin\\activemq.bat",
        "bin\\activemq-admin.bat"
    ],
    "persist": [
        "conf",
        "data"
    ],
    "checkver": {
        "url": "https://activemq.apache.org/components/classic/download",
        "regex": "apache-activemq-([\\d.]+)-bin\\.zip"
    },
    "autoupdate": {
        "url": "https://downloads.apache.org/activemq/$version/apache-activemq-$version-bin.zip",
        "hash": {
            "url": "$url.sha512"
        },
        "extract_dir": "apache-activemq-$version"
    }
}
