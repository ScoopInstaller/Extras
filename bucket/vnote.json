{
    "version": "4.2.0",
    "description": "A Vim-inspired note-taking platform",
    "homepage": "https://app.vnote.fun",
    "license": "LGPL-3.0-only",
    "notes": [
        "VNote does not auto-migrate non-portable settings into the portable `config` folder.",
        "If you used VNote before this change, copy your old settings into the persist folder once:",
        "from `%APPDATA%\\VNoteX\\VNote`, `%LOCALAPPDATA%\\VNoteX\\VNote`, `%APPDATA%\\vnote`, or `%LOCALAPPDATA%\\VNote`",
        "to `$persist_dir\\config` (or let the install script migrate when that folder is empty)."
    ],
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/vnotex/vnote/releases/download/v4.2.0/VNote-4.2.0-win64.zip",
            "hash": "9acbdfa45156f8ebbb627edaec3cf0322867fdf2b12c2be9ef057ae9a729d8cc",
            "extract_dir": "VNote-4.2.0-win64\\bin"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config\")) { New-Item \"$persist_dir\\config\" -ItemType Directory | Out-Null }",
        "$targets = @(",
        "    \"$env:APPDATA\\VNoteX\\VNote\",",
        "    \"$env:LOCALAPPDATA\\VNoteX\\VNote\",",
        "    \"$env:APPDATA\\vnote\",",
        "    \"$env:LOCALAPPDATA\\VNote\"",
        ")",
        "if (-not (Test-Path -Path \"$persist_dir\\config\\*\")) {",
        "    foreach ($src in $targets) {",
        "        if (Test-Path -Path \"$src\\*\") {",
        "            Write-Host \"INFO  Migrating VNote settings from '$src' to '$persist_dir\\config'...\" -ForegroundColor DarkGray",
        "            Copy-Item -Path \"$src\\*\" -Destination \"$persist_dir\\config\" -Force -Recurse -ErrorAction SilentlyContinue",
        "            break",
        "        }",
        "    }",
        "}"
    ],
    "bin": "vnote.exe",
    "shortcuts": [
        [
            "vnote.exe",
            "VNote"
        ]
    ],
    "persist": "config",
    "checkver": {
        "github": "https://github.com/vnotex/vnote"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/vnotex/vnote/releases/download/v$version/VNote-$version-win64.zip",
                "extract_dir": "VNote-$version-win64\\bin"
            }
        }
    }
}
