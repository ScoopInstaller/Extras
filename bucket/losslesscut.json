{
    "version": "3.68.0",
    "description": "Lossless trimming tool for video and audio files",
    "homepage": "https://losslesscut.app",
    "license": "GPL-2.0-or-later",
    "notes": [
        "For .mp4 and .mkv file associations, run:",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/mifi/lossless-cut/releases/download/v3.68.0/LosslessCut-win-x64.7z",
            "hash": "37751d9ef2128d1a625505c46e9992b3aecd0937a6a907d1c20d9be2bce45045"
        }
    },
    "post_install": [
        "$losslesscutPath = \"$dir\".Replace('\\', '\\\\')",
        "'install-associations', 'uninstall-associations' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\") {",
        "        $content = (Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_.reg\").Replace('$losslesscut', $losslesscutPath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_.reg\" -Encoding Ascii",
        "    }",
        "}"
    ],
    "bin": "LosslessCut.exe",
    "shortcuts": [
        [
            "LosslessCut.exe",
            "LosslessCut"
        ]
    ],
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-associations.reg\" }"
    },
    "checkver": {
        "github": "https://github.com/mifi/lossless-cut"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mifi/lossless-cut/releases/download/v$version/LosslessCut-win-x64.7z"
            }
        }
    }
}
