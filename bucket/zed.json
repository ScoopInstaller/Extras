{
    "version": "0.214.6",
    "description": "Zed is a high-performance, multiplayer code editor from the creators of Atom and Tree-sitter. It's also open source.",
    "homepage": "https://zed.dev/",
    "license": "AGPL-3.0, Apache-2.0, GPL-3.0",
    "notes": [
        "Add Zed as a context menu option by running:",
        "reg import \"$dir\\install-context.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/zed-industries/zed/releases/download/v0.214.6/Zed-x86_64.exe",
            "hash": "2a8208c84c7c7513fe7dae2c098cb0f6a3f19d6b94fa617781cae3a2aa1cea96"
        },
        "arm64": {
            "url": "https://github.com/zed-industries/zed/releases/download/v0.214.6/Zed-aarch64.exe",
            "hash": "28d48ed43a58a98a3da01618bccc78e1312fa17d3468f7f77105af93664f2195"
        }
    },
    "installer": {
        "script": [
            "Expand-InnoArchive -Path \"$dir\\$fname\" -ExtractDir '{app}'",
            "Expand-InnoArchive -Path \"$dir\\$fname\" -ExtractDir '{code_GetInstallDir}' -Removal"
        ]
    },
    "post_install": [
        "$exepath = \"$dir\\zed.exe\".Replace('\\', '\\\\')",
        "'install-context.reg', 'uninstall-context.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$zed-path', $exepath)",
        "        if ($global) {",
        "            $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "        }",
        "    }",
        "    $content | Set-Content -Path \"$dir\\$_\" -Encoding ascii",
        "}"
    ],
    "bin": "bin\\zed.exe",
    "pre_uninstall": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-context.reg\" }",
    "shortcuts": [
        [
            "zed.exe",
            "Zed"
        ]
    ],
    "checkver": {
        "github": "https://github.com/zed-industries/zed"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-x86_64.exe"
            },
            "arm64": {
                "url": "https://github.com/zed-industries/zed/releases/download/v$version/Zed-aarch64.exe"
            }
        }
    }
}
