{
    "version": "12.4.1",
    "description": "Open platform for analytics and data monitoring",
    "homepage": "https://grafana.com/",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://dl.grafana.com/oss/release/grafana-12.4.1.windows-amd64.zip",
            "hash": "ac5470e93b5521d43eb97f6cbf201aebfc2d34dad7418d93572ad8360b1b7615"
        },
        "arm64": {
            "url": "https://dl.grafana.com/oss/release/grafana-12.4.1.windows-arm64.zip",
            "hash": "e9b20a44a194ec9c2077501dd4e0ebbe67780e180c171651ad4da776f6a978c6"
        }
    },
    "extract_dir": "grafana-12.4.1",
    "bin": [
        "bin\\grafana-cli.exe",
        [
            "bin\\grafana-server.exe",
            "grafana-server",
            "-homepath \"$dir\""
        ]
    ],
    "persist": [
        "conf",
        "data"
    ],
    "checkver": {
        "url": "https://grafana.com/grafana/download?edition=oss&platform=windows",
        "regex": "grafana_([\\d.]+)_(?<stamp>[\\d]+)_windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.grafana.com/oss/release/grafana-$version.windows-amd64.zip"
            },
            "arm64": {
                "url": "https://dl.grafana.com/oss/release/grafana-$version.windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "grafana-$version"
    }
}
