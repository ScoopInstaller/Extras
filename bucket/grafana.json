    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://dl.grafana.com/oss/release/grafana-13.0.2.windows-amd64.zip",
            "hash": "62a88edf06da95918fd9154a27a08a1919c635094ce2e2f7b24c87ee12076d6f"
        },
        "arm64": {
            "url": "https://dl.grafana.com/oss/release/grafana-13.0.2.windows-arm64.zip",
            "hash": "8b58c9940b6db281c4d9d33145acf20a49a10f3bba9cb97acbc1c91890d73f0b"
        }
    },
    "extract_dir": "grafana-13.0.2",
    "bin": [
        "bin\\grafana.exe",
        [
            "bin\\grafana.exe",
            "grafana-cli",
            "cli"
        ],
        [
            "bin\\grafana.exe",
            "grafana-server",
            "server -homepath \"$dir\""
        ]
    ],
    "persist": [
        "conf",
        "data"
    ],
    "checkver": {
        "url": "https://grafana.com/grafana/download?edition=oss&platform=windows",
        "regex": "grafana_([\\d.]+(?:\\+security-\\d+)?)_(?<stamp>[\\d]+)_windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.grafana.com/oss/release/grafana-$version.windows-amd64.zip"
            },
            "arm64": {
                "url": "https://dl.grafana.com/oss/release/grafana-$version.windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "grafana-$version"
    }
}
