    },
    "suggest": {
        "JDK": [
            "java/oraclejdk",
            "java/openjdk"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://artifacts.elastic.co/downloads/logstash/logstash-8.19.17-windows-x86_64.zip",
            "hash": "sha512:2253faf258d7f419ccc16fa3c176e4fb30e2d70958d7100c56bb23aabe2e7b74622ee5441c47d3d5d715972adc7d28e4124202528cc624a32ad83b920d182897"
