{
    "version": "3.2.2",
    "description": "GNU Image Manipulation Program",
    "homepage": "https://www.gimp.org",
    "license": "GPL-3.0-only",
    "url": "https://download.gimp.org/mirror/pub/gimp/v3.2/windows/gimp-3.2.2-setup.exe",
    "hash": "cbdcdb49c144d5ef26693f03939fff22770bed22b83da7c420cdfe78a18b383e",
    "innosetup": true,
    "installer": {
        "script": [
            "# Set path for the execution of this script",
            "Push-Location -Path $dir",
            "# Remove debug files",
            "Get-ChildItem -Filter '*.debug' -Recurse | Remove-Item -Recurse",
            "# Rename architecture specific files for making the rest of the script easier",
            "$File64 = [array](",
            "    Get-ChildItem -File -Recurse -Filter '*,?.*' | Where-Object -FilterScript {",
            "        $_.Name -match '^(.*?),[12]\\.(.*?)$' -and",
            "        (-not (Test-Path (Join-Path -Path $_.Directory.FullName -ChildPath \"$($matches[1]),3.$($matches[2])\"))) -and",
            "        $matches[1] -ne 'libhwy'",
            "    }",
            ")",
            "$File64.Where{$_.Name -match ',2'} | Rename-Item -NewName { $_.name -Replace ',2', ',x64' }",
            "$File64.Where{$_.Name -match ',1'} | Rename-Item -NewName { $_.name -Replace ',1', ',arm' }",
            "",
            "# 64bits",
            "if ($architecture -eq '64bit') {",
            "    Get-ChildItem -Filter '*,x64*' -Recurse | Rename-Item -NewName { $_.name -Replace ',x64', '' }",
            "}",
            "# 32bits",
            "elseif ($architecture -eq '32bit') {",
            "    throw '32bit is unsupported now!'",
            "}",
            "# ARM64",
            "else {",
            "    Get-ChildItem -Filter '*,arm*' -Recurse | Rename-Item -NewName { $_.name -Replace ',arm', '' }",
            "}",
            "# Remove all architecture specific files that has not yet been renamed",
            "$null = Get-ChildItem -Filter '*,*' -Recurse -File | Remove-Item",
            "# Set path back to what it was before this script started",
            "Pop-Location"
        ]
    },
    "bin": [
        "bin\\gimp-console-3.2.exe",
        [
            "bin\\gimp-console-3.2.exe",
            "gimp-console"
        ],
        [
            "bin\\gimp-console-3.2.exe",
            "gimp"
        ],
        "bin\\gimptool-3.2.exe",
        [
            "bin\\gimptool-3.2.exe",
            "gimptool"
        ]
    ],
    "shortcuts": [
        [
            "bin\\gimp-3.2.exe",
            "GIMP"
        ]
    ],
    "checkver": {
        "url": "https://www.gimp.org/downloads/",
        "regex": "gimp-(?<version>[\\d.]+)-setup(?<build>-\\d)?\\.exe",
        "replace": "${version}${build}"
    },
    "autoupdate": {
        "url": "https://download.gimp.org/mirror/pub/gimp/v$majorVersion.$minorVersion/windows/gimp-$matchHead-setup$matchTail.exe",
        "hash": {
            "url": "$baseurl/SHA256SUMS"
        },
        "bin": [
            "bin\\gimp-console-$majorVersion.$minorVersion.exe",
            [
                "bin\\gimp-console-$majorVersion.$minorVersion.exe",
                "gimp-console"
            ],
            [
                "bin\\gimp-console-$majorVersion.$minorVersion.exe",
                "gimp"
            ],
            "bin\\gimptool-$majorVersion.$minorVersion.exe",
            [
                "bin\\gimptool-$majorVersion.$minorVersion.exe",
                "gimptool"
            ]
        ],
        "shortcuts": [
            [
                "bin\\gimp-$majorVersion.$minorVersion.exe",
                "GIMP"
            ]
        ]
    }
}
