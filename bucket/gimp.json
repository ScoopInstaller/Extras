{
    "version": "3.2.0",
    "description": "GNU Image Manipulation Program",
    "homepage": "https://www.gimp.org",
    "license": "GPL-3.0-only",
    "url": "https://download.gimp.org/mirror/pub/gimp/v3.2/windows/gimp-3.2.0-setup.exe",
    "hash": "6332ab8fdf9d1f229abd7aab18874d476ae31405e2fe75bf786b8fdc90b891a8",
    "innosetup": true,
    "installer": {
        "script": [
            "# Set path for the execution of this script",
            "Push-Location -Path \"$dir\"",
            "# Remove debug files",
            "Get-ChildItem -Filter '*.debug' -Recurse | Remove-Item -Recurse",
            "# Rename architecture specific files for making the rest of the script easier",
            "$File64 = [array](",
            "    Get-ChildItem -File -Recurse -Filter '*,?.*' | Where-Object -FilterScript {",
            "        $_.Name -match '^(.*?),[12]\\.(.*?)$' -and",
            "        (-not (Test-Path (Join-Path -Path $_.Directory.FullName -ChildPath \"$($matches[1]),3.$($matches[2])\"))) -and",
            "        $matches[1] -ne 'libhwy'",
            "    }",
            ")",
            "$File64.Where{$_.Name -match ',2'} | Rename-Item -NewName { $_.name -Replace ',2', ',3' }",
            "$File64.Where{$_.Name -match ',1'} | Rename-Item -NewName { $_.name -Replace ',1', ',2' }",
            "# If 32bit",
            "if ($architecture -eq '32bit') {",
            "    # Remove \",1\" from all files that have it in the file name",
            "    Get-ChildItem -Filter '*,1*' -Recurse | Rename-Item -NewName { $_.name -Replace ',1', '' }",
            "}",
            "# Else: 64bit or ARM64",
            "else {",
            "    # 'twain.exe' is for 'gimp32on64' which is not included.",
            "    $PluginsDir = [string](",
            "        Resolve-Path -Path \"$dir\\lib\\gimp\\*\\plug-ins\" | Select-Object -ExpandProperty 'Path'",
            "    )",
            "    $null = Remove-Item \"$PluginsDir\\twain\" -Recurse -Force -ErrorAction Ignore",
            "    # If 64bit: Remove \",2\" from all files that have it in the file name",
            "    if ($architecture -eq '64bit') {",
            "        Get-ChildItem -Filter '*,2*' -Recurse | Rename-Item -NewName { $_.name -Replace ',2', '' }",
            "    }",
            "    # If ARM64: Remove \",3\" from all files that have it in the file name",
            "    else {",
            "        Get-ChildItem -Filter '*,3*' -Recurse | Rename-Item -NewName { $_.name -Replace ',3', '' }",
            "    }",
            "}",
            "# Remove all architecture specific files that has not yet been renamed",
            "$null = Get-ChildItem -Filter '*,*' -Recurse -File | Remove-Item",
            "# Set path back to what it was before this script started",
            "Pop-Location"
        ]
    },
    "bin": [
        "bin\\gimp-console-3.2.exe",
        [
            "bin\\gimp-console-3.2.exe",
            "gimp-console"
        ],
        [
            "bin\\gimp-console-3.2.exe",
            "gimp"
        ],
        "bin\\gimptool-3.2.exe",
        [
            "bin\\gimptool-3.2.exe",
            "gimptool"
        ]
    ],
    "shortcuts": [
        [
            "bin\\gimp-3.2.exe",
            "GIMP"
        ]
    ],
    "checkver": {
        "url": "https://www.gimp.org/downloads/",
        "regex": "gimp-(?<version>[\\d.]+)-setup(?<build>-\\d)?\\.exe",
        "replace": "${version}${build}"
    },
    "autoupdate": {
        "url": "https://download.gimp.org/mirror/pub/gimp/v$majorVersion.$minorVersion/windows/gimp-$matchHead-setup$matchTail.exe",
        "hash": {
            "url": "$baseurl/SHA256SUMS"
        },
        "bin": [
            "bin\\gimp-console-$majorVersion.$minorVersion.exe",
            [
                "bin\\gimp-console-$majorVersion.$minorVersion.exe",
                "gimp-console"
            ],
            [
                "bin\\gimp-console-$majorVersion.$minorVersion.exe",
                "gimp"
            ],
            "bin\\gimptool-$majorVersion.$minorVersion.exe",
            [
                "bin\\gimptool-$majorVersion.$minorVersion.exe",
                "gimptool"
            ]
        ],
        "shortcuts": [
            [
                "bin\\gimp-$majorVersion.$minorVersion.exe",
                "GIMP"
            ]
        ]
    }
}
