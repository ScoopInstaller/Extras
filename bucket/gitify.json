{
    "version": "7.0.0",
    "description": "GitHub notifications on menu bar",
    "homepage": "https://www.gitify.io",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitify-app/gitify/releases/download/v7.0.0/Gitify-Setup-7.0.0.exe#/dl.7z",
            "hash": "sha512:97910764095ea7c508a65acbc634703dbe30995effa57f63fe23c79b2bb8d72770370abd3e8198d93de7bb15aa3142bad571a1f2f8f809fea22543faea3dc9fc",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Gitify.exe",
            "Gitify"
        ]
    ],
    "checkver": {
        "github": "https://github.com/gitify-app/gitify"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gitify-app/gitify/releases/download/v$version/Gitify-Setup-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
