{
    "version": "7.0.1",
    "description": "GitHub notifications on menu bar",
    "homepage": "https://www.gitify.io",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitify-app/gitify/releases/download/v7.0.1/Gitify-Setup-7.0.1.exe#/dl.7z",
            "hash": "sha512:85cd95cd231289eb3132c5824bcf8a710380d0c1ece7138d4f3997346754f4cd912472c37ee1671b3d7d58b788751ad8a8cfecd9a19e92a04b00436393d50fbe",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Gitify.exe",
            "Gitify"
        ]
    ],
    "checkver": {
        "github": "https://github.com/gitify-app/gitify"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gitify-app/gitify/releases/download/v$version/Gitify-Setup-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
