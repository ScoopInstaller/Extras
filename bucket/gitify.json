{
    "version": "6.19.0",
    "description": "GitHub notifications on menu bar",
    "homepage": "https://www.gitify.io",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitify-app/gitify/releases/download/v6.19.0/Gitify-Setup-6.19.0.exe#/dl.7z",
            "hash": "sha512:ed8feed4dd58af097a2ff2a5833376be131d970e3cb3432f31e96949b63b05b1743d640ec1dbca2ba2793ea752910e71db30d1cb990ef2103636529a493b6870",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Gitify.exe",
            "Gitify"
        ]
    ],
    "checkver": {
        "github": "https://github.com/gitify-app/gitify"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gitify-app/gitify/releases/download/v$version/Gitify-Setup-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
