    "description": "GitHub notifications on menu bar",
    "homepage": "https://www.gitify.io",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/gitify-app/gitify/releases/download/v6.18.0/Gitify-Setup-6.18.0.exe#/dl.7z",
            "hash": "sha512:832198b4cde05db3e6085bdd1ba89a2d0adf3c1899e90c448e53ff8d1d19b3422c1a71e5704beca07d2f98db3d6e16fff10cf14515148714f7302c2ba97eec31",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
