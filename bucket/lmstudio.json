            "hash": "e01cffa0a0c3e29cfc52bf9ff89f2afdd662d2d5a81c464648bbcad77a88ed58"
        },
        "arm64": {
            "url": "https://installers.lmstudio.ai/win32/arm64/0.4.19-2/LM-Studio-0.4.19-2-arm64.exe#/dl.7z",
