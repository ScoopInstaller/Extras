{
    "homepage": "https://openwork.software/",
    "version": "0.16.4",
    "description": "An open-source alternative to Claude Cowork, powered by opencode ",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/different-ai/openwork/releases/download/v0.16.4/openwork-win-x64-0.16.4.exe#/dl.7z",
            "hash": "eaedde0311a884115044a07886a211c25a842b5e160a7610699270191b3adb9b"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": "Expand-7zipArchive \"$dir\\app-64.7z\" $dir -Removal",
    "post_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "    ensure \"$persist_dir\" | Out-Null",
        "}",
        "if (!(Test-Path \"$persist_dir\\data\")) {",
        "    ensure \"$persist_dir\\data\" | Out-Null",
        "}",
        "New-Item $env:AppData\\com.differentai.openwork -ItemType Junction -Target \"$persist_dir\\data\" | Out-Null"
    ],
    "shortcuts": [
        [
            "openwork.exe",
            "openwork (different-ai)"
        ]
    ],
    "pre_uninstall": [
        "if (Test-Path \"$Env:AppData\\com.differentai.openwork\\*\") {",
        "    Remove-Item $env:APPDATA\\com.differentai.openwork -Force -Recurse",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/different-ai/openwork"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/different-ai/openwork/releases/download/v$version/openwork-win-x64-$version.exe"
            }
        }
    }
}
