{
    "version": "4.0.3-1",
    "description": "A free and open source geographic information system (GIS), with optional projection grids",
    "homepage": "https://www.qgis.org/",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://download.qgis.org/downloads/QGIS-Grids-OSGeo4W-4.0.3-1.msi",
            "hash": "d845ebadf5fd85b91a2a0ae3bb49c890f75caeb7d862730e4eefda5af1e507a6"
        }
    },
    "extract_dir": "QGIS 4.0.3",
    "post_install": "& \"$dir\\etc\\postinstall.bat\" \"$(shortcut_folder $global)\\OSGeo4W\" \"%USERPROFILE%\\Desktop\" 0 1",
    "bin": "OSGeo4W.bat",
    "pre_uninstall": "& \"$dir\\etc\\preremove.bat\"",
    "checkver": {
        "url": "https://github.com/qgis/QGIS-Website/raw/main/data/conf.json",
        "jsonpath": "$.lr_grids_msi",
        "regex": "/QGIS-Grids-OSGeo4W-([\\d.]+(-\\d+)?)\\.msi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.qgis.org/downloads/QGIS-Grids-OSGeo4W-$version.msi",
                "hash": {
                    "url": "https://download.qgis.org/downloads/QGIS-Grids-OSGeo4W-$version.sha256sum"
                }
            }
        },
        "extract_dir": "QGIS $majorVersion.$minorVersion.$patchVersion"
    }
}
