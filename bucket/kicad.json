{
    "version": "10.0.3",
    "description": "Electronics Design Automation Suite",
    "homepage": "https://www.kicad.org",
    "license": "GPL-3.0-only",
    "notes": [
        "To create file-associations for .kicad_* and kicad old files, run '$dir\\install-file-associations.reg'"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/KiCad/kicad-source-mirror/releases/download/10.0.3/kicad-10.0.3-x86_64.exe#/dl.7z",
            "hash": "c2751315f4b8e19239a88f2055f6dbcceabec56f5a3fab726269cebd04333971"
        },
        "arm64": {
            "url": "https://github.com/KiCad/kicad-source-mirror/releases/download/10.0.3/kicad-10.0.3-arm64.exe#/dl.7z",
            "hash": "27b9798725784ddafce02b02a92aa1bc6ef605cdd17387957808f5967a615a7a"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\" -Recurse",
    "post_install": [
        "'install-file-associations', 'uninstall-file-associations' | ForEach-Object {",
        "    $reg_file_in  = \"$bucketsdir\\main\\scripts\\kicad\\$_.reg\"",
        "    $reg_file_out = \"$dir\\$_.reg\"",
        "    $kicad_root     = \"$dir\".Replace('\\', '\\\\')",
        "    if (Test-Path $reg_file_in) {",
        "        $content = Get-Content $reg_file_in",
        "        $content = $content.Replace('$kicad_root', $kicad_root)",
        "        if ($global) {",
        "            $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "        }",
        "        Set-Content -Path $reg_file_out -Value $content -Encoding Ascii",
        "    }",
        "}"
    ],
    "post_uninstall": [
        "'uninstall-file-associations' | ForEach-Object {",
        "    $reg_file = \"$dir\\$_.reg\"",
        "    if (Test-Path $reg_file) {",
        "        regedit /s $reg_file",
        "    }",
        "}"
    ],
    "bin": "bin\\kicad-cli.exe",
    "shortcuts": [
        [
            "bin\\kicad.exe",
            "KiCad"
        ],
        [
            "bin\\eeschema.exe",
            "Schematic Editor"
        ],
        [
            "bin\\pcbnew.exe",
            "PCB Editor"
        ],
        [
            "bin\\gerbview.exe",
            "Gerber Viewer"
        ],
        [
            "bin\\pcb_calculator.exe",
            "Calculator Tools"
        ],
        [
            "bin\\pl_editor.exe",
            "Drawing Sheet Editor"
        ],
        [
            "bin\\bitmap2component.exe",
            "Image Converter"
        ],
        [
            "bin\\kicad-cmd.bat",
            "KiCad Command Prompt"
        ]
    ],
    "checkver": {
        "github": "https://github.com/KiCad/kicad-source-mirror",
        "jsonpath": "$.assets[*].browser_download_url",
        "regex": "kicad-([\\d.]+(?:-\\d+)?)-x86_64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/KiCad/kicad-source-mirror/releases/download/$matchHead/kicad-$version-x86_64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/KiCad/kicad-source-mirror/releases/download/$matchHead/kicad-$version-arm64.exe#/dl.7z"
            }
        }
    }
}
