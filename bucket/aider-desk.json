{
    "version": "0.59.0",
    "description": "Desktop application for Aider AI assistant",
    "homepage": "https://github.com/hotovo/aider-desk",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/hotovo/aider-desk/releases/download/v0.59.0/aider-desk-0.59.0-setup.exe#/dl.7z",
            "hash": "sha512:0f4efac9aeed1e998c5fc0ecabfc1edd6780e918fc203126467fab17a6fa5c6714a7bb39fe6c9a940f22e88ddf3a244e65dd3f800eaaebc1362c60d028dce30a",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninst*\" -Recurse"
            ]
        }
    },
    "post_uninstall": "Remove-Item \"$env:APPDATA\\aider-desk\" -Recurse -Force",
