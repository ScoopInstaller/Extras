{
    "version": "0.73.0",
    "description": "Desktop application for Aider AI assistant",
    "homepage": "https://github.com/hotovo/aider-desk",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/hotovo/aider-desk/releases/download/v0.73.0/aider-desk-0.73.0-setup.exe#/dl.7z",
            "hash": "sha512:f58fdfcc7f9b97a395dee2857a5740e61f1676202a53480eba4825fdb8e7a69d4a1f55f8be98e1d6d7ca263c8a6df5ba42433d2d2bd7e9f4f3ee0608359f10a9",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninst*\" -Recurse"
            ]
        }
    },
    "post_uninstall": "Remove-Item \"$env:APPDATA\\aider-desk\" -Recurse -Force",
