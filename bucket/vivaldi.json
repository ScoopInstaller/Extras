            "hash": "19f8ae80530c0e237add45c20ed65d5e95fea1ac3cbca85169b5d7d8575ef267"
        },
        "arm64": {
            "url": "https://downloads.vivaldi.com/stable/Vivaldi.8.1.4087.56.arm64.exe#/dl.7z",
