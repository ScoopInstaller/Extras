        },
        "32bit": {
            "url": "https://downloads.vivaldi.com/stable/Vivaldi.8.1.4087.55.exe#/dl.7z",
            "hash": "ee147a2a9e13ccb7d3e4375664439c09cecc447f7e3fd6d65eb83190e06db8ad"
        },
        "arm64": {
            "url": "https://downloads.vivaldi.com/stable/Vivaldi.8.1.4087.55.arm64.exe#/dl.7z",
