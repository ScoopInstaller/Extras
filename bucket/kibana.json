    },
    "suggest": {
        "JDK": [
            "java/oraclejdk",
            "java/openjdk"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://artifacts.elastic.co/downloads/kibana/kibana-9.4.0-windows-x86_64.zip",
            "hash": "sha512:640c90139858d721eed42cb53f0d5120043e6eb09e8231146133a143d846df35be67113e146781eb2605f2eee97bd6917ef888436471e77b78f58a9c2c334f89",
