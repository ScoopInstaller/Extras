    ],
    "architecture": {
        "64bit": {
            "url": "https://download.jetbrains.com/python/pycharm-2026.1.2.win.zip",
            "hash": "a7fee2845f67ab37dff5d1abe7e44ec4d1db9d7c8ef6ea09494216aa7f44a014",
            "bin": [
                [
                    "IDE\\bin\\pycharm64.exe",
