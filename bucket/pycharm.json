    ],
    "architecture": {
        "64bit": {
            "url": "https://download.jetbrains.com/python/pycharm-2025.3.4.win.zip",
            "hash": "ca5ffa0793253e1001e322a796fa60dfc25364e291987dd0dc86d2efb07d8259",
            "bin": [
