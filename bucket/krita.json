{
    "version": "5.3.0",
    "description": "A free digital painting application",
    "homepage": "https://krita.org/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/krita/5.3.0/krita-x64-5.3.0-setup.exe#/dl.7z",
            "hash": "a68293c352ce8a196ab9574eecebd61032a6fac8181ede4d5b7be373991c2156"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\" -Recurse -Force",
    "bin": [
        "bin\\krita.exe",
        "bin\\kritarunner.exe"
    ],
    "shortcuts": [
        [
            "bin\\krita.exe",
            "Krita"
        ]
    ],
    "checkver": {
        "url": "https://krita.org/en/download/",
        "regex": "Download Krita\\s+([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/krita/$version/krita-x64-$version-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
