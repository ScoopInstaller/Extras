{
    "version": "6.10",
    "description": "Extract hardcoded subtitles (hardsub) from video.",
    "homepage": "https://videosubfinder.sourceforge.io",
    "license": "GPL-2.0-only",
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/project/videosubfinder/VideoSubFinder_6.10_x64.zip",
            "hash": "sha1:9684d392159ec0284078f44acbe2208db8844794",
            "extract_dir": "Release_x64"
        },
        "32bit": {
            "url": "https://downloads.sourceforge.net/project/videosubfinder/VideoSubFinder_6.10_x86.zip",
            "hash": "sha1:2664cb6d02a29a5b4f7c564609316bcbfb3e0d61",
            "extract_dir": "Release"
        }
    },
    "shortcuts": [
        [
            "VideoSubFinderWXW.exe",
            "VideoSubFinder"
        ],
        [
            "VideoSubFinderWXW_intel.exe",
            "VideoSubFinder (Intel)"
        ]
    ],
    "persist": "settings",
    "checkver": {
        "sourceforge": "videosubfinder",
        "regex": "VideoSubFinder_([\\d.]+)_x64\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/project/videosubfinder/VideoSubFinder_$version_x64.zip"
            },
            "32bit": {
                "url": "https://downloads.sourceforge.net/project/videosubfinder/VideoSubFinder_$version_x86.zip"
            }
        }
    }
}
