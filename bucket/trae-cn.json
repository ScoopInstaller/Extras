{
    "##": "Extract to the IDE folder to avoid overwriting manifest.json, which would cause startup failure.",
    "version": "2.3.2839",
    "description": "An AI-powered IDE that makes programming more enjoyable and efficient.",
    "homepage": "https://www.trae.cn",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://lf-cdn.trae.com.cn/obj/trae-com-cn/pkg/app/releases/stable/2.3.2839/win32/Trae-Setup-x64.exe",
            "hash": "302D4654D74AC82D00487F8C6B7326B587BB457C759ECBF04C6539874D680E53"
        }
    },
    "innosetup": true,
    "extract_dir": "{code_GetDestDir}",
    "extract_to": "IDE",
    "bin": "IDE\\bin\\trae.cmd",
    "shortcuts": [
        [
            "IDE\\Trae.exe",
            "Trae"
        ]
    ],
    "checkver": {
        "url": "https://api.trae.cn/icube/api/v1/native/version/trae/latest",
        "jsonpath": "$.data.manifest.win32.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://lf-cdn.trae.com.cn/obj/trae-com-cn/pkg/app/releases/stable/$version/win32/Trae-Setup-x64.exe"
            }
        }
    }
}
