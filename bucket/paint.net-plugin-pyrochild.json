    "pre_install": [
        "$pluginFolder = Join-Path (appdir 'paint.net' $global) 'current\\Effects'",
        "Copy-Item \"$dir\\*.dll\" $pluginFolder -Force",
        "(Get-ChildItem \"$dir\\*.dll\").Name | Out-File \"$dir\\plugins.txt\" -Encoding Ascii"
    ],
    "uninstaller": {
