            "hash": "163043ec3b4494df5562cecb07816fc4abe0830277f070b68b60a4d63ccb56b3",
            "extract_dir": "zsh-patina-v1.4.0-x86_64-pc-cygwin"
        }
    },
    "env_add_path": ".",
