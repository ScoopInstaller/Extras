{
    "version": "2.11.0",
    "description": "#1 Locally hosted web application that allows you to perform various operations on PDF files",
    "homepage": "https://stirlingpdf.com",
    "license": "MIT",
    "suggest": {
        "JDK": [
            "java/openjdk21",
            "java/oraclejdk-lts",
            "java/temurin21-jre"
        ],
        "Python": "python",
        "QPDF": "qpdf",
        "LibreOffice": "extras/libreoffice",
        "Tesseract OCR": "tesseract",
        "Weasyprint": "weasyprint"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Stirling-Tools/Stirling-PDF/releases/download/v2.11.0/Stirling-PDF.jar",
            "hash": "9f240b50180979206ae72604101bf444c3cc5f573577419aaf5f97055d82ebbd"
        }
    },
    "pre_install": "Set-Content \"$dir\\stirling-pdf.bat\" '@start java.exe -jar \"%~dp0\\Stirling-PDF.jar\" %*' -Encoding Ascii",
    "shortcuts": [
        [
            "stirling-pdf.bat",
            "Stirling PDF"
        ]
    ],
    "persist": [
        "configs",
        "customFiles",
        "logs"
    ],
    "checkver": {
        "github": "https://github.com/Stirling-Tools/Stirling-PDF"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Stirling-Tools/Stirling-PDF/releases/download/v$version/Stirling-PDF.jar"
            }
        }
    }
}
