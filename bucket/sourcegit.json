        "    Remove-Item $env:AppData\\SourceGit -Force -Recurse",
        "}"
    ],
    "bin": "SourceGit.exe",
    "shortcuts": [
        [
            "SourceGit.exe",
            "SourceGit"
        ]
    ],
    "persist": "data",
