    "architecture": {
        "64bit": {
            "url": "https://github.com/win32ss/supermium/releases/download/v144-r1/supermium_144_64_setup_win10_11.exe#/dl.zip",
            "hash": "0ec0f2a843c8f0b9481b07078ff0ac93c80c226d4b01682d729c9da59309bef3"
        },
        "32bit": {
            "url": "https://github.com/win32ss/supermium/releases/download/v144-r1/supermium_144_32_setup.exe#/dl.zip",
            "hash": "a343faa79ec9ea2edb92ca1539c7f86f11d870b58d94a0de7f24bf61879d8b07"
        }
    },
    "extract_dir": "Supermium",
    "post_install": [
        "if (-not (Test-Path \"$dir\\User Data\\*\") -and (Test-Path \"$env:LocalAppData\\Supermium\\User Data\")) {",
        "    info '[Portable Mode]: Copying user data...'",
        "    Copy-Item -Path \"$env:LocalAppData\\Supermium\\User Data\\*\" -Destination \"$dir\\User Data\" -Force -Recurse",
        "    Remove-Item -Path \"$env:LocalAppData\\Supermium\" -Recurse -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": [
        [
            "chrome.exe",
            "supermium",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Supermium",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\chrome.exe"
    },
    "persist": "User Data",
    "checkver": {
        "url": "https://api.github.com/repos/win32ss/supermium/releases/latest",
        "jsonpath": "$..['tag_name', 'name']",
        "regex": "(?i)\"(?<tag>v?[\\d]+(?<suffix>-[^\"]+)?)\",\"[^\"]+?(?<prefix>[\\d.]+)",
        "replace": "${prefix}${suffix}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/win32ss/supermium/releases/download/$matchTag/supermium_$majorVersion_64_setup_win10_11.exe#/dl.zip"
            },
            "32bit": {
                "url": "https://github.com/win32ss/supermium/releases/download/$matchTag/supermium_$majorVersion_32_setup.exe#/dl.zip"
            }
        }
    }
}
