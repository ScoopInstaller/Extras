{
    "version": "6.0.0",
    "description": "Cross-platform Desktop App for android messages.",
    "homepage": "https://github.com/OrangeDrangon/android-messages-desktop",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/OrangeDrangon/android-messages-desktop/releases/download/v6.0.0/Android-Messages-v6.0.0-win-x64.portable.exe#/dl.7z",
            "hash": "sha512:78009e4b9b2b8b95fdd9ec172092a61bb602f0ccd11de02af416cd24f0913b7496e7d11c9d09886330bff64ce203504e17e497b230af410be63c989f5fc75eb3",
            "extract_dir": "$PLUGINSDIR"
        }
    },
    "installer": {
        "script": [
            "Remove-Item \"$dir\\*\" -Exclude 'app-64.7z'",
            "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\" -Removal"
        ]
    },
    "bin": [
        [
            "Android Messages.exe",
            "AndroidMessages"
        ]
    ],
    "shortcuts": [
        [
            "Android Messages.exe",
            "Android Messages"
        ]
    ],
    "checkver": {
        "url": "https://github.com/OrangeDrangon/android-messages-desktop/releases",
        "regex": "/tree/v([\\w.-]+)\""
    },
    "autoupdate": {
        "url": "https://github.com/OrangeDrangon/android-messages-desktop/releases/download/v$version/Android-Messages-v$version-win-x64.portable.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
