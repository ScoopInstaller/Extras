        "    Copy-Item \"$persist_dir\\data\\*\" \"$dir\\User Data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\User Data\\*\") -and (Test-Path \"$env:LocalAppData\\BraveSoftware\\Brave-Browser\\User Data\")) {",
