    "installer": {
        "script": [
            "Rename-Item \"$dir\\`$INSTDIR`$_8_\" 'InstallData'",
            "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse -Force"
        ]
    },
    "checkver": {
        "url": "https://www.reaper.fm/download.php",
        "regex": "Version ([\\d.]+)"
    },
    "autoupdate": {
