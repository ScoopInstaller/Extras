            "hash": "f8d1770c260a5631942d4c75235ee7e68803d06cd474e183a92e25ecca501e43"
        },
        "32bit": {
            "url": "https://github.com/NickeManarin/ScreenToGif/releases/download/2.43/ScreenToGif.2.43.Portable.x86.zip",
            "hash": "21a09f7d61238831ef7b991283081686c57ee443c271dbe6ba24824cdfd37816"
