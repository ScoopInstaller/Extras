{
    "version": "1.34.84",
    "description": "Fast, lightweight, advanced system information tool for your PC.",
    "homepage": "https://www.ccleaner.com/speccy",
    "license": "Freeware",
    "url": "https://download.ccleaner.com/spsetup134.exe#/dl.7z",
    "hash": "a7f525daeb124f90d2a07d2975f40b9ee568d56244902d3418728ce6dfd737f0",
    "architecture": {
        "64bit": {
            "bin": [
                [
                    "Speccy64.exe",
                    "Speccy"
                ]
            ],
            "shortcuts": [
                [
                    "Speccy64.exe",
                    "Speccy"
                ]
            ]
        },
        "32bit": {
            "bin": "Speccy.exe",
            "shortcuts": [
                [
                    "Speccy.exe",
                    "speccy"
                ]
            ]
        }
    },
    "pre_install": [
        "# Construct EXE file name based on $architecture",
        "$FileName = [string] 'Speccy{0}.exe' -f $(if($architecture -eq '64bit'){'64'})",
        "# Copy EXE to $dir root",
        "Get-ChildItem -Path \"$dir\" -Recurse -File -Name $FileName |",
        "    ForEach-Object -Process {",
        "        Move-Item -Path \"$dir\\$_\" -Destination \"$dir\"",
        "    }",
        "# Remove everything else",
        "Get-ChildItem -Path $dir |",
        "    Where-Object -Property 'Name' -ne $FileName |",
        "    ForEach-Object -Process {",
        "        Remove-Item -Recurse -Force -Path $_.FullName",
        "    }",
        "# Set settings",
        "Set-Content -Path \"$dir\\portable.dat\" -Value '#PORTABLE#' -Encoding ASCII",
        "if (-not (Test-Path \"$persist_dir\\Speccy.ini\")) {",
        "    Set-Content \"$dir\\Speccy.ini\" (@('[Software\\Piriform\\Speccy]', 'NeedUpdate=0') -join \"`r`n\") -Encoding ASCII",
        "}"
    ],
    "persist": "Speccy.ini",
    "checkver": {
        "url": "https://www.ccleaner.com/speccy/version-history",
        "regex": ">v([\\d.]+)<"
    },
    "autoupdate": {
        "url": "https://download.ccleaner.com/spsetup$majorVersion$minorVersion.exe#/dl.7z"
    }
}
