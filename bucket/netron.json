            "hash": "sha512:dbb6c645f7235df7a200b3aa52e20eda262d6c1ddced9974ccf59d631ed4c6ceb0c80e972b6398f92111580912b35ef0833e240694237dcf59f61d1a2ffb47f5",
            "pre_install": [
