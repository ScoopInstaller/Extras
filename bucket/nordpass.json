        "architecture": {
            "64bit": {
                "url": "https://downloads.npass.app/windows/NordPassSetup.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512:\\s$base64"
                }
            }
        }
    }
