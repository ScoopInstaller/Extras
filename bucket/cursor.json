{
    "version": "0.47.5",
    "description": "The AI Code Editor",
    "homepage": "https://www.cursor.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.cursor.com/terms-of-service"
    },
    "notes": [
        "This is a portable installation of Cursor. Your data is stored in the 'data' directory.",
        "After installation, your existing Cursor data has been migrated to the portable location."
    ],
    "architecture": {
        "64bit": {
            "url": "https://downloads.cursor.com/production/53d6da1322f934a1058e7569ee0847b24879d18c/win32/x64/user-setup/CursorUserSetup-x64-0.47.5.exe",
            "hash": "5df2c647c4b4a195f27b61ca657b483bd8bf561053ecac2878d63b3d777b6d83",
            "installer": {
                "script": [
                    "# Install silently to app directory",
                    "Start-Process -Wait -FilePath \"$dir\\CursorUserSetup-x64-$version.exe\" -ArgumentList \"/VERYSILENT\", \"/SUPPRESSMSGBOXES\", \"/NORESTART\", \"/SP-\", \"/DIR=`\"$dir`\"\"",
                    "Remove-Item \"$dir\\CursorUserSetup-x64-$version.exe\" -Force"
                ]
            }
        },
        "arm64": {
            "url": "https://downloads.cursor.com/production/53d6da1322f934a1058e7569ee0847b24879d18c/win32/arm64/user-setup/CursorUserSetup-arm64-0.47.5.exe",
            "hash": "b1fc1ed2535e187e2533595bc2b8fbfaaa0b61ce118b02aad586f1f3613bc28b",
            "installer": {
                "script": [
                    "# Install silently to app directory",
                    "Start-Process -Wait -FilePath \"$dir\\CursorUserSetup-arm64-$version.exe\" -ArgumentList \"/VERYSILENT\", \"/SUPPRESSMSGBOXES\", \"/NORESTART\", \"/SP-\", \"/DIR=`\"$dir`\"\"",
                    "Remove-Item \"$dir\\CursorUserSetup-arm64-$version.exe\" -Force"
                ]
            }
        }
    },
    "post_install": [
        "# Create data directories",
        "New-Item -ItemType Directory -Force -Path \"$dir\\data\\user-data\" | Out-Null",
        "New-Item -ItemType Directory -Force -Path \"$dir\\data\\extensions\" | Out-Null",
        "# Create portable marker file",
        "New-Item -ItemType File -Force -Path \"$dir\\data\\portable-data\" | Out-Null",
        "# Copy existing data",
        "if (!(Test-Path \"$dir\\data\\extensions\\*\") -and (Test-Path \"$env:USERPROFILE\\.cursor\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.cursor\\extensions\\*\" \"$dir\\data\\extensions\" -Recurse -ErrorAction SilentlyContinue",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\\*\") -and (Test-Path \"$env:APPDATA\\Cursor\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:APPDATA\\Cursor\\*\" \"$dir\\data\\user-data\" -Recurse -ErrorAction SilentlyContinue",
        "    # Remove original data after successful copy",
        "    if (Test-Path \"$dir\\data\\user-data\\*\") {",
        "        info '[Portable Mode] Removing original AppData folder...'",
        "        Remove-Item \"$env:APPDATA\\Cursor\" -Force -Recurse -ErrorAction SilentlyContinue",
        "    }",
        "}",
        "# Clean up installer-created shortcuts",
        "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Cursor*\" -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$env:ProgramData\\Microsoft\\Windows\\Start Menu\\Programs\\Cursor*\" -Force -ErrorAction SilentlyContinue"
    ],
    "env_set": {
        "CURSOR_USER_DATA_DIR": "$dir\\data\\user-data",
        "CURSOR_EXTENSIONS_DIR": "$dir\\data\\extensions"
    },
    "bin": [
        [
            "Cursor.exe",
            "cursor"
        ]
    ],
    "shortcuts": [
        [
            "Cursor.exe",
            "Cursor"
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://raw.githubusercontent.com/oslook/cursor-ai-downloads/main/version-history.json",
        "regex": "\"version\":\\s*\"([\\d.]+)\"[\\s\\S]*?\"win32-x64\":\\s*\"https://downloads\\.cursor\\.com/production/([\\w]+)/win32/x64/user-setup/CursorUserSetup-x64-[\\d.]+\\.exe\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.cursor.com/production/$match2/win32/x64/user-setup/CursorUserSetup-x64-$version.exe"
            },
            "arm64": {
                "url": "https://downloads.cursor.com/production/$match2/win32/arm64/user-setup/CursorUserSetup-arm64-$version.exe"
            }
        }
    }
}