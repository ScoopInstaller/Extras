{
    "version": "0.47.5",
    "description": "The AI Code Editor",
    "homepage": "https://www.cursor.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.cursor.com/terms-of-service"
    },
    "notes": "This is a portable installation of Cursor. Your data is stored in the 'data' directory.",
    "architecture": {
        "64bit": {
            "url": "https://cursor.so/win",
            "hash": "5df2c647c4b4a195f27b61ca657b483bd8bf561053ecac2878d63b3d777b6d83"
        },
        "arm64": {
            "url": "https://downloads.cursor.com/production/53d6da1322f934a1058e7569ee0847b24879d18c/win32/arm64/user-setup/CursorUserSetup-arm64-0.47.5.exe#/cursor-installer.exe",
            "hash": "b1fc1ed2535e187e2533595bc2b8fbfaaa0b61ce118b02aad586f1f3613bc28b"
        }
    },
    "installer": {
        "script": [
            "# Debug info for troubleshooting",
            "info 'Extracting installer...'",
            "Expand-7zipArchive \"$dir\\$fname\" \"$dir\\extracted\" -Removal",

            "# List all files to help diagnose structure",
            "info 'Listing extracted files for debugging:'",
            "Get-ChildItem \"$dir\\extracted\" -Recurse | Select-Object -First 20 | ForEach-Object { info \"Found file: $_\" }",

            "# Look for all archives in the extracted files",
            "info 'Looking for any archive files...'",
            "$allArchives = Get-ChildItem \"$dir\\extracted\" -Recurse -File -Include *.7z,*.zip,*.tar,*.rar,*.nupkg | Select-Object -First 10",
            "if ($allArchives.Count -gt 0) {",
            "    $allArchives | ForEach-Object { info \"Found archive: $_\" }",
            "}",

            "# Try to find the app archive with multiple patterns",
            "$appArchives = @()",
            "$appArchives += Get-ChildItem \"$dir\\extracted\" -Recurse -File -Include \"app*.7z\", \"*.nupkg\", \"*cursor*.7z\", \"*app*.7z\"",

            "# Check for files in $PLUGINSDIR which often contains the actual application files",
            "$pluginsDir = Join-Path \"$dir\\extracted\" \"`$PLUGINSDIR\"",
            "if (Test-Path $pluginsDir) {",
            "    info \"Found `$PLUGINSDIR directory, checking contents...\"",
            "    Get-ChildItem $pluginsDir -File | ForEach-Object { info \"Found in plugins dir: $_\" }",
            "    ",
            "    # Try to find larger files which might be the app archives",
            "    $largeFiles = Get-ChildItem $pluginsDir -File | Where-Object { $_.Length -gt 10MB } | Sort-Object Length -Descending",
            "    if ($largeFiles.Count -gt 0) {",
            "        info \"Found large files that might be archives:\"",
            "        $largeFiles | ForEach-Object { info \"$($_.Name) - $($_.Length/1MB) MB\" }",
            "        $appArchives += $largeFiles | Select-Object -First 1",
            "    }",
            "}",

            "if ($appArchives.Count -eq 0) {",
            "    Write-Error \"Could not find any app archive in the installer.\"",
            "    exit 1",
            "}",

            "info \"Found $($appArchives.Count) app archives. Using the first one: $($appArchives[0].FullName)\"",
            "Expand-7zipArchive $appArchives[0].FullName \"$dir\" -Removal",

            "# Verify cursor.exe exists",
            "if (!(Test-Path \"$dir\\Cursor.exe\")) {",
            "    info \"Cursor.exe not found in root directory. Looking for it recursively...\"",
            "    $cursorExe = Get-ChildItem \"$dir\" -Recurse -File -Include \"Cursor.exe\" | Select-Object -First 1",
            "    if ($cursorExe) {",
            "        info \"Found Cursor.exe at: $($cursorExe.FullName)\"",
            "        Copy-Item $cursorExe.FullName \"$dir\\Cursor.exe\" -Force",
            "    } else {",
            "        Write-Error \"Could not find Cursor.exe in the extracted files.\"",
            "    }",
            "}",

            "# Clean up unnecessary files",
            "Remove-Item \"$dir\\extracted\" -Recurse -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\Uninst*\" -Recurse -Force -ErrorAction SilentlyContinue"
        ]
    },
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.cursor\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.cursor\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Cursor\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Cursor\" \"$dir\\data\\user-data\" -Recurse",
        "}"
    ],
    "shortcuts": [
        [
            "Cursor.exe",
            "Cursor"
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://raw.githubusercontent.com/oslook/cursor-ai-downloads/main/version-history.json",
        "regex": "\"version\":\\s*\"([\\d.]+)\"[\\s\\S]*?\"win32-x64\":\\s*\"https://downloads\\.cursor\\.com/production/([\\w]+)/win32/x64/user-setup/CursorUserSetup-x64-[\\d.]+\\.exe\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.cursor.com/production/$match2/win32/x64/user-setup/CursorUserSetup-x64-$version.exe#/cursor-installer.exe"
            },
            "arm64": {
                "url": "https://downloads.cursor.com/production/$match2/win32/arm64/user-setup/CursorUserSetup-arm64-$version.exe#/cursor-installer.exe"
            }
        }
    }
}

