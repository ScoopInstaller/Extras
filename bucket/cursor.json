{
    "version": "0.47.5",
    "description": "The AI Code Editor",
    "homepage": "https://www.cursor.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.cursor.com/terms-of-service"
    },
    "notes": "This is a portable installation of Cursor. Your data is stored in the 'data' directory.",
    "architecture": {
        "64bit": {
            "url": "https://downloads.cursor.com/production/53d6da1322f934a1058e7569ee0847b24879d18c/win32/x64/user-setup/CursorUserSetup-x64-0.47.5.exe#/dl.exe",
            "hash": "5df2c647c4b4a195f27b61ca657b483bd8bf561053ecac2878d63b3d777b6d83"
        },
        "arm64": {
            "url": "https://downloads.cursor.com/production/53d6da1322f934a1058e7569ee0847b24879d18c/win32/arm64/user-setup/CursorUserSetup-arm64-0.47.5.exe#/dl.exe",
            "hash": "b1fc1ed2535e187e2533595bc2b8fbfaaa0b61ce118b02aad586f1f3613bc28b"
        }
    },
    "installer": {
        "script": [
            "# First extract installer",
            "info 'Extracting installer EXE...'",
            "Expand-7zipArchive \"$dir\\dl.exe\" \"$dir\" -Removal",

            "# List all files to debug",
            "info 'Listing extracted contents:'",
            "Get-ChildItem \"$dir\" -Force | ForEach-Object { info $_.FullName }",

            "# List all 7z archives in the extracted files",
            "info 'Looking for app archives:'",
            "$appArchives = @(Get-ChildItem \"$dir\" -Recurse -Force -File -Include \"*.7z\")",
            "foreach ($archive in $appArchives) {",
            "    info \"Found archive: $($archive.FullName)\"",
            "}",

            "if ($appArchives.Count -gt 0) {",
            "    $appArchive = $appArchives[0]",
            "    info \"Using archive: $($appArchive.FullName)\"",
            "    ",
            "    # Extract app archive",
            "    info 'Extracting app archive...'",
            "    Expand-7zipArchive $appArchive.FullName \"$dir\\app\" -Removal",
            "    ",
            "    # Copy all files from app directory to main directory",
            "    info 'Moving app files to main directory...'",
            "    Get-ChildItem \"$dir\\app\" -Recurse | Move-Item -Destination \"$dir\" -Force",
            "} else {",
            "    Write-Error \"Could not find any app archive (*.7z) in the installer.\"",
            "    exit 1",
            "}",

            "# Verify the cursor.exe exists",
            "if (!(Test-Path \"$dir\\Cursor.exe\")) {",
            "    info \"Cursor.exe not found in root directory. Looking for it recursively...\"",
            "    $cursorExe = Get-ChildItem \"$dir\" -Recurse -File -Include \"Cursor.exe\" | Select-Object -First 1",
            "    if ($cursorExe) {",
            "        info \"Found Cursor.exe at: $($cursorExe.FullName)\"",
            "        Copy-Item $cursorExe.FullName \"$dir\\Cursor.exe\"",
            "    } else {",
            "        Write-Error \"Could not find Cursor.exe in the extracted files.\"",
            "    }",
            "}",

            "# Clean up unnecessary files",
            "Remove-Item \"$dir\\`$*\" -Recurse -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\Uninst*\" -Recurse -Force -ErrorAction SilentlyContinue"
        ]
    },
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.cursor\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.cursor\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Cursor\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Cursor\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=cursor(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "shortcuts": [
        [
            "Cursor.exe",
            "Cursor"
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://raw.githubusercontent.com/oslook/cursor-ai-downloads/main/version-history.json",
        "regex": "\"version\":\\s*\"([\\d.]+)\"[\\s\\S]*?\"win32-x64\":\\s*\"https://downloads\\.cursor\\.com/production/([\\w]+)/win32/x64/user-setup/CursorUserSetup-x64-[\\d.]+\\.exe\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.cursor.com/production/$match2/win32/x64/user-setup/CursorUserSetup-x64-$version.exe#/dl.exe"
            },
            "arm64": {
                "url": "https://downloads.cursor.com/production/$match2/win32/arm64/user-setup/CursorUserSetup-arm64-$version.exe#/dl.exe"
            }
        }
    }
}

