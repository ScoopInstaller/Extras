    "installer": {
        "script": [
            "Remove-Item \"$dir\\resources\" -Recurse -Force -ErrorAction SilentlyContinue",
            "Get-Item \"$dir\\`$PLUGINSDIR\\app*.7z\" | Expand-7zipArchive -DestinationPath \"$dir\"",
            "Remove-Item \"$dir\\`$*\" -Force -Recurse"
