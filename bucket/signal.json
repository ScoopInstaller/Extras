    "post_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*.exe\" -Recurse -Force",
    "shortcuts": [
        [
            "Signal.exe",
            "Signal"
        ]
    ],
    "checkver": {
        "url": "https://updates.signal.org/desktop/latest.yml",
