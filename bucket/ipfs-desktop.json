            "hash": "sha512:cc5fcbdadd12473c047ebcbb013b113f9138a52de2ebce3ec7b5de802b6294c8df6d4e5584eab88b4cf2c2019b01aecbc2e95429bc9015de8405f36e4deeca99",
            "pre_install": [
