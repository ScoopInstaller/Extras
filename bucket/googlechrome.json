        "arm64": {
            "url": "https://dl.google.com/release2/chrome/e4qdzhvyoylowvucxx7yvepnve_148.0.7778.179/148.0.7778.179_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "bf8c2a83db507cd84666b00b37ea7da9491703e585307673588159ca71d70654"
