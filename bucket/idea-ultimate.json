                    "JetBrains\\IDEA"
                ]
            ]
        },
        "arm64": {
            "url": "https://download.jetbrains.com/idea/idea-2026.1-aarch64.win.zip",
            "hash": "a3c3e0904b2bc0e9caeec97a5019b8f52066c2360c141a611250a2e9dd3c064b",
            "bin": [
                [
                    "IDE\\bin\\idea64.exe",
                    "idea"
