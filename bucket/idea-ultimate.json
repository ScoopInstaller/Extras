    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.jetbrains.com/idea/idea-$matchVer.win.zip"
            },
            "arm64": {
                "url": "https://download.jetbrains.com/idea/idea-$matchVer-aarch64.win.zip"
            }
