                    "IDE\\bin\\idea64.exe",
                    "JetBrains\\IDEA"
                ]
            ]
        },
        "arm64": {
            "url": "https://download.jetbrains.com/idea/idea-2025.3.4-aarch64.win.zip",
            "hash": "c6662e397703bec80e3fd19a3b7c1bc9437e9cca1cba98350a563eb6650c9544",
            "bin": [
                [
                    "IDE\\bin\\idea64.exe",
