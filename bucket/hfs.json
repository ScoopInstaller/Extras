{
    "version": "3.1.1",
    "description": "A web file server to run on your computer",
    "homepage": "https://rejetto.com/hfs",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/rejetto/hfs/releases/download/v3.1.1/hfs-windows-x64-3.1.1.zip",
            "hash": "9106bde5c02f2f4e16d4942f9335213d5589a83ee5b533fa16d4fdf76d13354b"
        }
    },
    "pre_install": "if (!(Test-Path \"$persist_dir\\config.yaml\")) { New-Item \"$dir\\config.yaml\" | Out-Null }",
    "bin": [
        [
            "hfs.exe",
            "hfs",
            "--cwd $dir"
        ]
    ],
    "shortcuts": [
        [
            "hfs.exe",
            "HFS",
            "--cwd $dir"
        ]
    ],
    "persist": [
        "config.yaml",
        "logs",
        "plugins"
    ],
    "checkver": {
        "github": "https://github.com/rejetto/hfs"
    },
    "autoupdate": {
        "url": "https://github.com/rejetto/hfs/releases/download/v$version/hfs-windows-x64-$version.zip"
    }
}
