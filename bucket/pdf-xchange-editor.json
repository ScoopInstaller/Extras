{
    "version": "11.0.1.0",
    "description": "A fast and feature-rich PDF viewer/editor.",
    "homepage": "https://www.pdf-xchange.com/product/pdf-xchange-editor",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.pdf-xchange.com/PDFXLicense_2026.pdf"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.pdf-xchange.com/downloads/PXCEditor11_Portable_x64.zip?version=11.0.1.0",
            "hash": "4195b2516512bbe9298272bd1fca8c8d5f546c5d21ff898ced992c338cc05049"
        },
        "32bit": {
            "url": "https://www.pdf-xchange.com/downloads/PXCEditor11_Portable_x86.zip?version=11.0.1.0",
            "hash": "8f0428a66b1bca05b95fa5096b35e68543a925eb0cdd9d5d240d755141c9a569"
        }
    },
    "pre_install": [
        "# Hard links are not applicable here because the application creates a new file instead of modifying the existing one in place.",
        "'History', 'Settings' | ForEach-Object {",
        "    if (Test-Path -Path \"$persist_dir\\$_.dat\" -PathType Container) {",
        "        Remove-Item -Path \"$persist_dir\\$_.dat\" -Recurse -Force -ErrorAction SilentlyContinue",
        "    }",
        "    if (Test-Path -Path \"$persist_dir\\$_.dat\" -PathType Leaf) {",
        "        Copy-Item -Path \"$persist_dir\\$_.dat\" -Destination $dir -Force",
        "    }",
        "}"
    ],
    "bin": "PXCEditor.exe",
    "shortcuts": [
        [
            "PXCEditor.exe",
            "PDF-XChange Editor"
        ]
    ],
    "pre_uninstall": [
        "# Hard links are not applicable here because the application creates a new file instead of modifying the existing one in place.",
        "ensure $persist_dir | Out-Null",
        "'History', 'Settings' | ForEach-Object {",
        "    if (Test-Path -Path \"$dir\\$_.dat\" -PathType Leaf) {",
        "        Copy-Item -Path \"$dir\\$_.dat\" -Destination $persist_dir -Force",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.pdf-xchange.com/product/pdf-xchange-editor/history/download-text-file",
        "regex": "Build ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.pdf-xchange.com/downloads/PXCEditor$majorVersion_Portable_x64.zip?version=$version"
            },
            "32bit": {
                "url": "https://www.pdf-xchange.com/downloads/PXCEditor$majorVersion_Portable_x86.zip?version=$version"
            }
        }
    }
}
