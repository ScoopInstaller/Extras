Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\seelen-ui.uri]
@="URL:com.seelen.seelen-ui protocol"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\seelen-ui.uri\DefaultIcon]
@="\"{{seelen_dir}}\\seelen-ui.exe\",0"

[HKEY_CURRENT_USER\Software\Classes\seelen-ui.uri\shell]

[HKEY_CURRENT_USER\Software\Classes\seelen-ui.uri\shell\open]

[HKEY_CURRENT_USER\Software\Classes\seelen-ui.uri\shell\open\command]
@="\"{{seelen_dir}}\\seelen-ui.exe\" \"%1\""
